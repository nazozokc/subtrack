{
  "name": "subtrack",
  "version": "2.1.6",
  "author": "nazozokc",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "bin": {
    "subtrack": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI tool to manage subscription services from the terminal",
  "keywords": [
    "cli",
    "subscription",
    "finance",
    "tracker",
    "terminal",
    "sqlite",
    "budget"
  ],
  "homepage": "https://github.com/nazozokc/subtrack",
  "bugs": {
    "url": "https://github.com/nazozokc/subtrack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nazozokc/subtrack.git"
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:typos": "typos",
    "lint:security": "pnpm audit --audit-level=high",
    "lint:types": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "gunshi": "^0.35.1",
    "picocolors": "^1.1.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11",
    "tsdown": "^0.22.2",
    "tsx": "^4.19.0",
    "typescript": "^6",
    "vitest": "^4"
  }
}
